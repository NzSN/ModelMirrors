# Test output
test --test_output=errors
common --noincompatible_disallow_ctx_resolve_tools
# Mount apalache into sandbox so tests can find apalache-mc and its jar
test --sandbox_add_mount_pair=/home/nzsn/.local/bin/apalache
# apalache-mc's config parser fails with "Configuration error: Input
# length = 1" when no locale is set (the sandbox unsets LANG/LC_ALL)
test --test_env=LANG=C.UTF-8
test --test_env=LC_ALL=C.UTF-8
